# ============================================================================
#  本文件是 docker-compose 读取的 .env 模板。
#  docker-compose.yml 在项目根目录，它会从「同目录（项目根）的 .env」做变量替换，
#  ⚠️ 因此 .env 必须放在项目根目录（与本文件同级），放在 backend/ 下 compose 读不到。
#  用法：把本文件复制为 .env 后按需修改：
#      cp .env.example .env
#  然后 docker compose up -d
#  注意：.env 含管理员密码等机密，已被 .gitignore 忽略，切勿提交。
# ============================================================================

# 服务监听
HOST=0.0.0.0
PORT=9010

# JWT 令牌有效期（分钟）
TOKEN_EXPIRE_MINUTES=1440

# 首次启动时创建的管理员账号（生产务必修改）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 自助注册总开关：默认关闭（0）。设为 1 才允许任意访客在登录页注册为普通用户。
# ⚠️ 开启后任何能访问站点的人都能建账号，请仅在可信内网或配合管理员审核时使用。
ALLOW_REGISTRATION=0
# 自助注册用户自动加入的默认分组（不填则用系统默认分组「默认分组」）
# REGISTER_DEFAULT_GROUP=默认分组

# 可选：直接指定 JWT 密钥；不填则自动生成并保存到 backend/.secret_key
# SECRET_KEY=your-very-secret-key

# ── HTTPS（可选，离线内网推荐）─────────────────────────────────────────────
# 先生成自签名证书（在部署服务器执行，需 openssl）：
#     bash backend/offline/gen_cert.sh <服务器IP> <域名>
#   产物落在 backend/ssl/（server.crt / server.key），compose 已挂载到 /app/ssl
# 然后取消下面两行注释并保持不变即可启用 HTTPS：
# SSL_CERTFILE=/app/ssl/server.crt
# SSL_KEYFILE=/app/ssl/server.key
# 明文 HTTP 端口（启用 SSL 时 307 跳转到 HTTPS），默认 9080
# HTTP_PORT=9080
# 是否启用明文->HTTPS 重定向（1 开启 / 0 关闭），默认 1
# SSL_REDIRECT=1
# HSTS 响应头（仅 TLS 启用时生效，1 开启 / 0 关闭），默认 0（自签名轮换避免锁死）
# HSTS=0
